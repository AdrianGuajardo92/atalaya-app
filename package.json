{
  "name": "atalaya-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 9000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "skills:sync": "./scripts/sync-skills.sh",
    "skills:validate": "python3 scripts/validate-skills.py",
    "skills:diff": "diff -ru -x .DS_Store .agents/skills .claude/skills",
    "skills:check": "npm run skills:validate && npm run skills:sync && npm run skills:diff",
    "study:validate": "npx tsx scripts/validate-study-data.ts",
    "study:validate:active": "npx tsx scripts/validate-study-data.ts --active",
    "study:audit:bible-modals": "npx tsx scripts/audit-bible-modals.ts",
    "study:audit:bible-modals:active": "npx tsx scripts/audit-bible-modals.ts --active",
    "study:remove": "npx tsx scripts/study-remove.ts",
    "study:list": "npx tsx scripts/study-list.ts",
    "article:remove": "npx tsx scripts/study-remove.ts",
    "article:list": "npx tsx scripts/study-list.ts",
    "cleanup-kv": "npx tsx scripts/cleanup-kv.ts"
  },
  "dependencies": {
    "@vercel/kv": "^3.0.0",
    "html-to-image": "^1.11.13",
    "next": "^16.2.10",
    "next-pwa": "^5.6.0",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.41",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "html2canvas": "^1.4.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "8.5.16",
    "serialize-javascript": "7.0.7"
  }
}
